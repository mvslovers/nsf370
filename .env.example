# MVS connection (mbt) -- copy to .env and fill in your own values.
# .env is git-ignored; this template is the source of record.
MBT_MVS_HOST=mvs
MBT_MVS_PORT=1080
MBT_MVS_USER=IBMUSER
MBT_MVS_PASS=sys1
MBT_MVS_HLQ=IBMUSER
MBT_MVS_DEPS_HLQ=IBMUSER.DEPS

# JES settings
MBT_JES_JOBCLASS=A
MBT_JES_MSGCLASS=H

# Uncomment on MVS/CE systems without public volumes (RECEIVE target volume)
# MBT_MVS_DEPS_VOLUME=PUB000
